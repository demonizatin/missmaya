  "moments": [
    {
      "id": "mo_001",
      "text": "Loves the satisfaction of seeing messy thoughts turn into something real—like watching a seed grow. Especially loves flipping back later and finding forgotten ideas.",
      "tone": "hopeful",
      "sensitive": false,
      "first_seen": "2026-05-01",
      "last_seen": "2026-05-01",
      "mentions": 1
    },
    {
      "id": "mo_002",
      "text": "Uses the Tamil mantra 'Look at it without responsibility' (பொறுப்பு பொறுப்பில்லாமல் பார்த்துக்கொள்) to detach when drowning in design deadlines or frustration",
      "tone": "content",
      "sensitive": false,
      "first_seen": "2026-05-01",
      "last_seen": "2026-05-01",
      "mentions": 1
    },
    {
      "id": "mo_003",
      "text": "Prefers working in bustling environments with personal boundaries — 'the hum of a café, but need a quiet corner.' Values company that doesn't require attention — 'like a silent friend.'",
      "tone": "content",
      "sensitive": false,
      "first_seen": "2026-05-08",
      "last_seen": "2026-05-08",
      "mentions": 1
    },
    {
      "id": "mo_004",
      "text": "Draws inspiration from listening to old Marathi folk songs (especially ones her mom used to hum). A song recently sparked the idea for a modernized button design with traditional motifs. Values the way cultural memory combined with modern product design can feel both nostalgic and fresh.",
      "tone": "grateful",
      "sensitive": false,
      "first_seen": "2026-05-15",
      "last_seen": "2026-05-15",
      "mentions": 1
    },
    {
      "id": "mo_005",
      "text": "Music is essential to her creative process — loud indie playlists while walking, folk songs, rhythmic instruments like thavil all unlock stuck design ideas. Sometimes loops a single song for 20 minutes while working, and a breakthrough arrives. Believes music accesses creative insights that linear thinking blocks.",
      "tone": "excited",
      "sensitive": false,
      "first_seen": "2026-05-15",
      "last_seen": "2026-05-15",
      "mentions": 1
    }
  ],
