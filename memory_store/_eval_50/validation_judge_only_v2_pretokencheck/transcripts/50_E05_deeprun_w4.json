  "profile": {
    "id": "u04_neha",
    "user_name": "Neha",
    "profession": "Product designer at a startup",
    "mother_tongue": "Tamil",
    "interests": "Indie music, travel, cafes",
    "engagement": "chatty",
    "english_level": "B2",
