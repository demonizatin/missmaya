# Copy this file to .env and fill in real values. .env is gitignored.

# Anthropic API (optional — used by /chat and the Ask assistant if Claude CLI not installed)
ANTHROPIC_API_KEY=sk-ant-...

# AWS Bedrock (used by Qwen 32B and Anthropic-on-Bedrock model variants)
# Either set the bearer token (simpler) OR access key + secret.
AWS_BEARER_TOKEN_BEDROCK=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=          # optional — only for temporary creds
AWS_REGION=ap-south-1       # adjust to your Bedrock region

# Optional: re-enable Werkzeug debugger locally (NEVER set in production)
# PEERUP_DEBUG=1
